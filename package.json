{
  "name": "portofolio-nanzzyy",
  "version": "1.0.0",
  "description": "Portfolio Nanda — Node.js + Tailwind CSS + Supabase",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "npm run build:css && concurrently \"nodemon server.js\" \"npm run watch:css\"",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css",
    "watch:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1",
    "tailwindcss": "^4.0.0"
  }
}
